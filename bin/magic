#!/usr/bin/env bash
# A `file`-like command line driver for the pure-Lisp magic library.
#
#   bin/magic [--mime] FILE...
#
# Uses the prebuilt standalone image (bin/magic.bin) when present for instant
# start-up; otherwise loads the system fresh each run via SBCL/ocicl. Build the
# fast image with `scripts/build-image.sh`.
set -euo pipefail
ROOT="$(cd "$(dirname "$0")/.." && pwd)"

if [[ -x "$ROOT/bin/magic.bin" ]]; then
  exec "$ROOT/bin/magic.bin" "$@"
fi

exec sbcl --noinform \
  --eval "(handler-bind ((warning #'muffle-warning)) (let ((*standard-output* (make-broadcast-stream))) (asdf:load-system \"magic\")))" \
  --eval "(uiop:quit (magic::run-cli (uiop:command-line-arguments)))" \
  --end-toplevel-options "$@"
